    "@nx/next": "^22.5.4",
    "@nx/workspace": "22.5.4",
    "@opennextjs/cloudflare": "^1.17.1",
    "@swc-node/register": "~1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "~1.15.5",
